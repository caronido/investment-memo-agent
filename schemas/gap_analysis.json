{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gap Analysis Output",
  "description": "Identifies missing information and follow-up questions after extraction from a call.",
  "type": "object",
  "properties": {
    "call_stage": {
      "type": "integer",
      "description": "Which call stage this gap analysis is for (1, 2, or 3)"
    },
    "company_name": {
      "type": "string"
    },
    "coverage_summary": {
      "type": "object",
      "description": "How well each memo section is covered so far",
      "properties": {
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "section_name": { "type": "string" },
              "coverage": { "type": "string", "enum": ["none", "partial", "sufficient", "complete"] },
              "missing_fields": { "type": "array", "items": { "type": "string" } },
              "notes": { "type": ["string", "null"] }
            },
            "required": ["section_name", "coverage"]
          }
        }
      }
    },
    "follow_up_questions": {
      "type": "array",
      "description": "Questions to ask in the next call or via email",
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string" },
          "priority": { "type": "string", "enum": ["critical", "important", "nice_to_have"] },
          "target_call": { "type": ["integer", "null"], "description": "Which call stage should address this (2 or 3)" },
          "memo_section": { "type": "string", "description": "Which memo section this question feeds into" }
        },
        "required": ["question", "priority", "memo_section"]
      }
    },
    "document_requests": {
      "type": "array",
      "description": "Documents to request from the founder",
      "items": {
        "type": "object",
        "properties": {
          "document": { "type": "string" },
          "priority": { "type": "string", "enum": ["critical", "important", "nice_to_have"] },
          "reason": { "type": "string" }
        },
        "required": ["document", "priority", "reason"]
      }
    },
    "data_quality_flags": {
      "type": "array",
      "description": "Potential issues with extracted data (contradictions, vague answers, etc.)",
      "items": {
        "type": "object",
        "properties": {
          "field": { "type": "string" },
          "issue": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] }
        },
        "required": ["field", "issue", "severity"]
      }
    }
  },
  "required": ["call_stage", "company_name", "coverage_summary", "follow_up_questions"]
}